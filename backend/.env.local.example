# Local LLM provider configuration
# Copy to backend/.env.local (or export in shell) and fill in your real values.

SUPERMARKS_LLM_PROVIDER=doubleword
SUPERMARKS_LLM_BASE_URL=https://api.doubleword.ai/v1
SUPERMARKS_LLM_API_KEY=replace-me

# Fast first-pass model (cheap/faster structural parse)
SUPERMARKS_KEY_PARSE_NANO_MODEL=replace-with-fast-visual-model

# Stronger escalation model for suspicious pages
SUPERMARKS_KEY_PARSE_MINI_MODEL=replace-with-stronger-visual-model

# Optional allowlist if you want to document valid provider models.
SUPERMARKS_KEY_PARSE_MODELS=replace-with-fast-visual-model,replace-with-stronger-visual-model
